# =============================================================================
# SARA — .gitignore
# =============================================================================

# ── Secrets (NEVER commit these) ─────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
pip-wheel-metadata/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Testing / Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── IDEs ─────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Node (travel-booking frontend) ───────────────────────────────────────────
node_modules/
.next/
dist/

# ── Model / data artefacts ───────────────────────────────────────────────────
model.pkl
*.pkl
*.joblib
