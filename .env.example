# =============================================================================
# SARA – Smart Airport Resource Analytics
# Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in your real values.
# NEVER commit `.env` to version control — add it to `.gitignore`.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Supabase PostgreSQL)
# -----------------------------------------------------------------------------
# Format:
#   postgresql+psycopg2://<user>:<password>@<host>:<port>/<dbname>
#
# Where to find these values:
#   Supabase Dashboard → Project Settings → Database → Connection string
#   Select "URI" mode and copy the string. Replace [YOUR-PASSWORD] with the
#   actual database password you set when creating the project.
#
# Supabase connection string typically looks like:
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# NOTE: Always use the "Transaction" pooler port (6543) for API backends,
#       NOT the direct connection port (5432), unless you're running migrations.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://postgres.<your-project-ref>:<your-db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
APP_ENV=development           # development | staging | production
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# -----------------------------------------------------------------------------
# TELEMETRY API
# -----------------------------------------------------------------------------
# API key for telemetry ingestion endpoint
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
TELEMETRY_API_KEY=your-telemetry-api-key-here

# -----------------------------------------------------------------------------
# SARA-specific settings (extend as needed)
# -----------------------------------------------------------------------------
# AIRPORT_IATA_CODE=DEL
# PREDICTION_HORIZON_HOURS=6
